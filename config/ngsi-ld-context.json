{
  "@context": {
    "_comment": "Nekazari Platform NGSI-LD @context — canonical namespace mappings. AutonomousMobileRobot and ManufacturingMachine are FIWARE Smart Data Models (SDM). Types prefixed 'nkz:' are platform extensions per SDM catalog audit 2026-05-03. Legacy AgriculturalRobot/AgriculturalTractor/AgriculturalImplement/AgriEquipment migrated to SDM 2026-05-03 — zero backward compat retained.",

    "schema": "https://schema.org/",
    "ngsi-ld": "https://uri.etsi.org/ngsi-ld/",
    "iot": "https://iot.schema.org/",
    "saref": "https://saref.etsi.org/core/",
    "saref4agri": "https://saref.etsi.org/saref4agri/",
    "nkz": "https://nekazari.robotika.cloud/ngsi-ld/",

    "AutonomousMobileRobot": {
      "@id": "https://smartdatamodels.org/dataModel.AutonomousMobileRobot/AutonomousMobileRobot",
      "@type": "@id",
      "_comment": "SDM AutonomousMobileRobot — FIWARE Smart Data Model for autonomous mobile robots. Replaces legacy nkz:AgriculturalRobot (2026-05-03 migration). Agricultural robots use category: agricultural."
    },
    "ManufacturingMachine": {
      "@id": "https://smartdatamodels.org/dataModel.ManufacturingMachine/ManufacturingMachine",
      "@type": "@id",
      "_comment": "SDM ManufacturingMachine — FIWARE Smart Data Model for industrial machinery. Replaces legacy nkz:AgriculturalTractor (category: tractor) and nkz:AgriculturalImplement (category: implement). Migrated 2026-05-03."
    },
    "AgriSensor": {
      "@id": "nkz:AgriSensor",
      "@type": "@id",
      "_comment": "Platform extension — SAREF4AGRI has no generic AgriSensor class (only specific types: Pluviometer, Thermometer, etc.)."
    },
    "AgriParcel": {
      "@id": "nkz:AgriParcel",
      "@type": "@id",
      "_comment": "Platform extension — SAREF4AGRI uses s4agri:Parcel, not AgriParcel."
    },
    "AgriOperation": {
      "@id": "nkz:AgriOperation",
      "@type": "@id",
      "_comment": "Platform extension — no SAREF4AGRI equivalent."
    },
    "AgriParcelOperation": {
      "@id": "nkz:AgriParcelOperation",
      "@type": "@id",
      "_comment": "Platform extension — SDM AgriParcelOperation lacks agricultural machinery kinematics properties. Platform extends with A-B lines and VRA fields."
    },
    "AgriCropObservation": {
      "@id": "nkz:AgriCropObservation",
      "@type": "@id",
      "_comment": "Platform extension of SDM AgriCrop (which lacks observation/image capture semantics)."
    },
    "WeatherObserved": {
      "@id": "nkz:WeatherObserved",
      "@type": "@id",
      "_comment": "Platform extension — SAREF4AGRI has no WeatherObserved. SDM WeatherObserved exists in dataModel.Weather. Legacy mapping: saref4agri:WeatherObserved."
    },
    "SatelliteImageObservation": {
      "@id": "nkz:SatelliteImageObservation",
      "@type": "@id",
      "_comment": "Platform extension — no SAREF4AGRI equivalent. Legacy mapping: saref4agri:SatelliteImageObservation."
    },
    "VegetationIndex": {
      "@id": "nkz:VegetationIndex",
      "@type": "@id",
      "_comment": "Platform extension — no SAREF4AGRI equivalent. Legacy mapping: saref4agri:VegetationIndex."
    },
    "LivestockAnimal": {
      "@id": "nkz:LivestockAnimal",
      "@type": "@id",
      "_comment": "Platform extension — SAREF4AGRI has no LivestockAnimal class. Legacy mapping: saref4agri:LivestockAnimal."
    },
    "LivestockGroup": {
      "@id": "nkz:LivestockGroup",
      "@type": "@id",
      "_comment": "Platform extension — no SAREF4AGRI equivalent. Legacy mapping: saref4agri:LivestockGroup."
    },
    "LivestockFarm": {
      "@id": "nkz:LivestockFarm",
      "@type": "@id",
      "_comment": "Platform extension — no SAREF4AGRI equivalent. Legacy mapping: saref4agri:LivestockFarm."
    },
    "LivestockProduction": {
      "@id": "nkz:LivestockProduction",
      "@type": "@id",
      "_comment": "Platform extension — no SAREF4AGRI equivalent. Legacy mapping: saref4agri:LivestockProduction."
    },
    "PhotovoltaicInstallation": {
      "@id": "nkz:PhotovoltaicInstallation",
      "@type": "@id",
      "_comment": "Platform extension — no SAREF4AGRI equivalent. Legacy mapping: saref4agri:PhotovoltaicInstallation."
    },
    "EnergyStorageSystem": {
      "@id": "nkz:EnergyStorageSystem",
      "@type": "@id",
      "_comment": "Platform extension — no SAREF4AGRI equivalent. Legacy mapping: saref4agri:EnergyStorageSystem."
    },

