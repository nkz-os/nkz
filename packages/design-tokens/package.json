{
  "name": "@nekazari/design-tokens",
  "version": "0.1.0-alpha",
  "private": false,
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./css": "./dist/tokens.css",
    "./tailwind": "./dist/tailwind-preset.js",
    "./native": "./dist/native-tokens.js"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "build": "tsx src/build-css.ts && tsx src/build-tailwind.ts && tsx src/build-native.ts && tsup src/index.ts --format cjs,esm --dts --external react,react-dom",
    "dev": "tsx watch src/build-css.ts"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.2.2"
  }
}
