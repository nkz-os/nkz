{
  "name": "@nekazari/viewer-kit",
  "version": "0.1.0-alpha",
  "private": false,
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "type": "module",
  "files": ["dist", "README.md", "package.json"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --external react,react-dom,@nekazari/design-tokens,@nekazari/ui-kit"
  },
  "dependencies": {
    "@nekazari/design-tokens": "workspace:*",
    "@nekazari/ui-kit": "workspace:*",
    "clsx": "^2.1.1"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.2.2"
  }
}
